    this.tokens = [];
    this.pos = 0;
    this.done = true;
    this.typingTimer = null;
    this.pauseTimer = null;
    this.charDelay = 30;
    this.pauseFrame = 33.34;
    this.html = '';
    this.color = 'w';
  }

  cleanRawLine(value) {
    return String(value || '')
      .replace(/결\s*의/g, match => /\s/.test(match) ? '의 지' : '의지')
      .replace(/\\E\d+/g, '')
      .replace(/\\[YWRBGO]/g, '')
      .replace(/\^\d*/g, '')
      .replace(/[/%]+$/g, '')
      .replace(/[\t ]+$/gm, '')
      .trim();
  }

  isUsableLine(line) {
    if (!line) return false;
    if (/\\C/.test(line)) return false;
    if (/\\\[[^\]]+\]/.test(line)) return false;
    if (/@@|prototype|arguments/.test(line)) return false;
    const visual = line
      .replace(/&/g, '\n')
      .replace(/#/g, '\n')
      .replace(/\\[A-Za-z]\d*/g, '')
      .replace(/[/%]/g, '')
      .replace(/\^\d*/g, '');
    const lineCount = visual.split(/\n/).length;
    if (lineCount >= 4) return false;
    return true;
  }

  randomLine() {
    return this.lines[Math.floor(Math.random() * this.lines.length)] || '* ...';
  }

  say(raw) {
    this.stopTimers();
    this.tokens = this.tokenize(raw);
    this.pos = 0;
    this.done = false;
    this.html = '';
    this.color = 'w';
    this.el.innerHTML = '';
    this.step();
  }

  nextRandom() {
    this.say(this.randomLine());
  }

  stopTimers() {
    clearTimeout(this.typingTimer);
    clearTimeout(this.pauseTimer);
    this.typingTimer = null;
    this.pauseTimer = null;
  }

  tokenize(value) {
    const s = this.cleanRawLine(value);
    const out = [];
    for (let i = 0; i < s.length;) {
      const rest = s.slice(i);
      let m;
      if ((m = rest.match(/^\\E\d+/))) { i += m[0].length; continue; }
      if ((m = rest.match(/^\\([YWRBGO])/))) { out.push({type:'color', value:m[1].toLowerCase()}); i += m[0].length; continue; }
      if ((m = rest.match(/^\^(\d+)/))) { out.push({type:'pause', value:Number(m[1]) || 1}); i += m[0].length; continue; }
      if ((m = rest.match(/^\\[A-Za-z]\d*/))) { i += m[0].length; continue; }
      if ((m = rest.match(/^\\\[[^\]]+\]/))) { i += m[0].length; continue; }
      const ch = s[i++];
      if (ch === '&' || ch === '#') out.push({type:'text', value:'\n'});
      else if (ch === '/' || ch === '%' || ch === '^') {}
      else out.push({type:'text', value:ch});
    }
    return out;
  }

  esc(ch) {
    if (ch === '&') return '&amp;';
    if (ch === '<') return '&lt;';
    if (ch === '>') return '&gt;';
    if (ch === '"') return '&quot;';
    return ch;
  }

  appendText(ch) {
    if (ch === '\n') this.html += '\n';
    else this.html += `<span class="${this.color}">${this.esc(ch)}</span>`;
    this.el.innerHTML = this.html;
  }

  step() {
    this.stopTimers();
    while (this.pos < this.tokens.length) {
      const t = this.tokens[this.pos++];
      if (t.type === 'color') { this.color = t.value; continue; }
      if (t.type === 'text') {
        this.appendText(t.value);
        this.typingTimer = setTimeout(() => this.step(), this.charDelay);
        return;
      }
      if (t.type === 'pause') {
        this.pauseTimer = setTimeout(() => this.step(), Math.max(80, t.value * this.pauseFrame));
        return;
      }
    }
    this.done = true;
  }

  skipToNextPauseOrEnd() {
    this.stopTimers();
    if (this.done) { this.nextRandom(); return; }
    while (this.pos < this.tokens.length) {
      const t = this.tokens[this.pos++];
      if (t.type === 'color') { this.color = t.value; continue; }
      if (t.type === 'text') { this.appendText(t.value); continue; }
      if (t.type === 'pause') {
        this.pauseTimer = setTimeout(() => this.step(), Math.max(80, t.value * this.pauseFrame));
        return;
      }
    }
    this.done = true;
  }
}


function fitUndertaleScale() {
  const baseW = 640;
  const baseH = 480;
  const scale = Math.max(1, Math.floor(Math.min(window.innerWidth / baseW, window.innerHeight / baseH)));
  document.documentElement.style.setProperty('--ut-scale', String(scale));
}
window.addEventListener('resize', fitUndertaleScale);
fitUndertaleScale();

const dialogue = new UndertaleRandomDialogue(document.getElementById('text'), UNDERTALE_KR_LINES);
dialogue.nextRandom();
window.addEventListener('pointerdown', () => dialogue.skipToNextPauseOrEnd());

</script>
